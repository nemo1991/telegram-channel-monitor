/* tgmonitor — 现代 UI 样式表(浅色主题)
 *
 * 设计原则:
 *   1. 暗色导航 + 亮色内容区 — 现代工具标配(GitHub/Linear/Notion)
 *   2. 卡片式统计(Dashboard)圆角 + 浅阴影
 *   3. 清晰层级:标题/正文/提示三档字号
 *   4. 保留状态点颜色体系
 *
 * 状态色(Tailwind v3 调色板 — 2026 现代化,两主题共用):
 *   就绪  → #16a34a
 *   进行中→ #f59e0b
 *   错误  → #dc2626
 *   未配  → #94a3b8
 *   强调  → {accent}(由 ThemeManager 注入;浅色=#5b9cf5 / 暗色=#7bb4ff)
 *
 * 暗色模式:ThemeManager.apply(DARK) 时换 style_dark.qss,accent 占位符
 * 同步替换。Nav bar 通过 nav_bar.py 的 setStyleSheet 内联样式,不在此处。
 */

/* ===== 全局 ===== */
* {
    font-size: 13px;
}
QMainWindow {
    background: #f5f6fa;
}

/* ===== 内容区 ===== */
#contentArea {
    background: #f5f6fa;
}

/* ===== 头栏 ===== */
#headerBar {
    background: #ffffff;
    border-bottom: 1px solid #e2e4e9;
    min-height: 44px;
}
#appTitle {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a2e;
    letter-spacing: 0.3px;
}
#headerState {
    font-size: 13px;
    color: #5a5d64;
    font-weight: 500;
}
#headerActionBtn {
    padding: 4px 14px;
    border: 1px solid #d0d3da;
    border-radius: 4px;
    background: #ffffff;
    color: #5a5d64;
    font-size: 12px;
    font-weight: 500;
}
#headerActionBtn:hover {
    background: #edf0f5;
    border-color: #b0b4c0;
}
#headerActionBtn:pressed {
    background: #e2e4e9;
}

/* ===== 页面标题 ===== */
#pageTitle {
    font-size: 18px;
    font-weight: 700;
    color: #1a1a2e;
    padding: 0;
    margin: 0;
}

/* ===== 统计卡片 ===== */
#statCard {
    background: #ffffff;
    border: 1px solid #e2e4e9;
    border-radius: 10px;
    padding: 0;
}
#statCard:hover {
    border-color: #c8cbd4;
    background: #fafbfc;
}
#statValue {
    font-size: 24px;
    font-weight: 700;
    color: #1a1a2e;
}
QLabel[role="card-title"] {
    font-size: 12px;
    color: #7a7d88;
    font-weight: 500;
}

/* ===== 快速操作按钮 ===== */
#actionBtn {
    padding: 8px 18px;
    border: 1px solid #d0d3da;
    border-radius: 6px;
    background: #ffffff;
    color: #3a3d4a;
    font-size: 13px;
    font-weight: 500;
}
#actionBtn:hover {
    background: #edf0f5;
    border-color: #b0b4c0;
}
#actionBtn:pressed {
    background: #e2e4e9;
}

/* ===== 主要按钮(保存并应用等) ===== */
#primaryBtn {
    padding: 8px 24px;
    border: none;
    border-radius: 6px;
    background: {accent};
    color: #ffffff;
    font-size: 13px;
    font-weight: 600;
}
#primaryBtn:hover {
    background: {accentHover};
}
#primaryBtn:pressed {
    background: #3a7bd4;
}

/* ===== 通用按钮 ===== */
QPushButton {
    padding: 5px 14px;
    border: 1px solid #d0d3da;
    border-radius: 5px;
    background: #ffffff;
    color: #3a3d4a;
}
QPushButton:hover { background: #edf0f5; }
QPushButton:pressed { background: #e2e4e9; }
QPushButton:default {
    background: {accent};
    color: white;
    border: none;
}
QPushButton:default:hover { background: {accentHover}; }
QPushButton:disabled {
    color: #8a8d96;
    background: #f0f1f5;
    border-color: #e2e4e9;
}

/* ===== 输入框 ===== */
QLineEdit, QSpinBox {
    padding: 5px 10px;
    border: 1px solid #d0d3da;
    border-radius: 5px;
    background: #ffffff;
    color: #1a1a2e;
    selection-background-color: {accent};
}
QLineEdit:focus, QSpinBox:focus {
    border-color: {accent};
    outline: none;
}

/* ===== 复选框 ===== */
QCheckBox {
    spacing: 6px;
    color: #3a3d4a;
}

/* ===== 下拉框 ===== */
QComboBox {
    padding: 5px 10px;
    border: 1px solid #d0d3da;
    border-radius: 5px;
    background: #ffffff;
    color: #1a1a2e;
}
QComboBox:focus {
    border-color: {accent};
}
QComboBox::drop-down {
    border: none;
    width: 24px;
}

/* ===== 分组框 ===== */
QGroupBox {
    background: #ffffff;
    border: 1px solid #e2e4e9;
    border-radius: 8px;
    margin-top: 14px;
    padding: 20px 14px 14px 14px;
    font-weight: 600;
    font-size: 13px;
    color: #1a1a2e;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px;
    color: {accent};
    font-size: 13px;
}

/* ===== 列表 ===== */
QListWidget {
    background: #ffffff;
    border: 1px solid #e2e4e9;
    border-radius: 6px;
    outline: 0;
    padding: 2px;
}
QListWidget::item {
    min-height: 32px;
    padding: 4px 10px;
    border-bottom: 1px solid #f0f1f5;
    border-radius: 4px;
}
QListWidget::item:hover {
    background: #eaf3fc;
}
QListWidget::item:selected {
    background: #b6d0f0;
    color: #1a1a2e;
    border-left: 3px solid {accent};
}

/* ===== 表格 ===== */
QTableWidget {
    background: #ffffff;
    border: 1px solid #e2e4e9;
    border-radius: 6px;
    gridline-color: #f0f1f5;
    selection-background-color: #b6d0f0;
    selection-color: #1a1a2e;
}
QHeaderView::section {
    background: #fafbfc;
    color: #5a5d64;
    padding: 6px 10px;
    border: none;
    border-bottom: 1px solid #e2e4e9;
    font-weight: 600;
    font-size: 12px;
}

/* ===== 状态栏 ===== */
QStatusBar {
    background: #ffffff;
    border-top: 1px solid #e2e4e9;
    color: #5a5d64;
    font-size: 12px;
    padding: 2px 12px;
}
QStatusBar::item { border: none; }

/* ===== 滚动区域(设置页) ===== */
#settingsScroll {
    border: none;
    background: transparent;
}

/* ===== 频道卡片(ChannelWidget 上/下栏) ===== */
#channelCard {
    background: #ffffff;
    border: 1px solid #e2e4e9;
    border-radius: 10px;
}
#cardSectionTitle {
    font-size: 14px;
    font-weight: 700;
    color: #1a1a2e;
}

/* ===== 状态点(留作兼容,新 UI 用 emoji) ===== */
QFrame#statusDot {
    border-radius: 8px;
    min-width: 16px;
    max-width: 16px;
    min-height: 16px;
    max-height: 16px;
}
QFrame#statusDot[state="ready"]    { background: #16a34a; }
QFrame#statusDot[state="pending"]  { background: #f59e0b; }
QFrame#statusDot[state="error"]    { background: #dc2626; }
QFrame#statusDot[state="unset"]    { background: #94a3b8; }

/* ===== 提示 / Warn / Error ===== */
QLabel[role="hint"] {
    color: #8a8d92;
    font-size: 12px;
}
QLabel[role="warn"] {
    color: #cc8800;
    font-size: 12px;
}
QLabel[role="error"] {
    color: #d9534f;
    font-size: 12px;
}

/* ===== 消息详情面板 ===== */
#messageDetail {
    background: #ffffff;
    border-left: 1px solid #e2e4e9;
}
#metaCard {
    background: #fafbfc;
    border: 1px solid #e2e4e9;
    border-radius: 6px;
}